# get-ASAP 환경변수 설정 템플릿
# 이 파일을 .env로 복사 후 실제 값을 입력하세요:
#   cp .env.example .env
#   nano .env  (또는 원하는 편집기 사용)

# ──────────────────────────────────────────────
# Gmail OAuth 설정 (per D-08)
# ──────────────────────────────────────────────

# Google Cloud Console에서 다운로드한 OAuth 2.0 클라이언트 자격증명 파일 경로
GMAIL_CREDENTIALS_PATH=credentials.json

# OAuth 인증 완료 후 자동 생성되는 토큰 파일 경로 (로컬 인증 후 SCP로 서버 복사)
GMAIL_TOKEN_PATH=token.json

# ──────────────────────────────────────────────
# Notion 설정
# ──────────────────────────────────────────────

# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_TOKEN=

# 논문 저장 대상 데이터베이스 ID (없으면 NOTION_PARENT_PAGE_ID로 자동 생성)
# 형식: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (32자리 hex, 대시 제외)
NOTION_DATABASE_ID=

# DB 자동 생성 시 사용할 부모 페이지 ID (NOTION_DATABASE_ID 없을 때만 사용)
# 형식: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_PARENT_PAGE_ID=

# ──────────────────────────────────────────────
# 실행 설정
# ──────────────────────────────────────────────

# Gmail 체크 주기 (시간 단위, crontab 설정과 일치시킬 것, per D-04)
CHECK_INTERVAL_HOURS=6

# ──────────────────────────────────────────────
# 대시보드 설정
# ──────────────────────────────────────────────

# 대시보드 접근 허용 이메일 (쉼표 구분)
DASHBOARD_ALLOWED_EMAILS=
