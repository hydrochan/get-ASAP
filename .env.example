# get-ASAP 환경변수 설정 템플릿
# 이 파일을 .env로 복사 후 실제 값을 입력하세요:
#   cp .env.example .env
#   nano .env

# ──────────────────────────────────────────────
# Gmail OAuth 설정
# ──────────────────────────────────────────────

# Google Cloud Console에서 다운로드한 OAuth 2.0 클라이언트 자격증명 파일 경로
GMAIL_CREDENTIALS_PATH=credentials.json

# OAuth 인증 완료 후 자동 생성되는 토큰 파일 경로 (로컬 인증 후 SCP로 서버 복사)
GMAIL_TOKEN_PATH=token.json

# ──────────────────────────────────────────────
# Notion 설정
# ──────────────────────────────────────────────

# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_TOKEN=

# 논문 저장 대상 데이터베이스 ID (없으면 NOTION_PARENT_PAGE_ID로 자동 생성)
NOTION_DATABASE_ID=

# DB 자동 생성 시 사용할 부모 페이지 ID (NOTION_DATABASE_ID 없을 때만 사용)
NOTION_PARENT_PAGE_ID=

# ──────────────────────────────────────────────
# 실행 설정
# ──────────────────────────────────────────────

# Gmail 체크 주기 (시간 단위, crontab과 일치시킬 것)
CHECK_INTERVAL_HOURS=6

# CSV 캐시 강제 갱신 시 현재 월과 함께 다시 읽을 이전 월 수
# 월말 논문이 다음 달에 분류 완료되는 경우를 반영하기 위해 기본 1 권장
CACHE_REFRESH_LOOKBACK_MONTHS=1

# ──────────────────────────────────────────────
# 대시보드 인증 (다중 사용자)
# ──────────────────────────────────────────────

# 사용자명 → bcrypt 해시 매핑 (JSON 한 줄)
# 해시 생성: python -c "import bcrypt; print(bcrypt.hashpw(b'비밀번호', bcrypt.gensalt()).decode())"
# 예: DASHBOARD_USERS={"admin":"$2b$12$abc...","user1":"$2b$12$xyz..."}
DASHBOARD_USERS=

# 관리자 사용자명 목록 (쉼표 구분, Stats 탭 접근 권한 부여)
# 예: DASHBOARD_ADMINS=admin
DASHBOARD_ADMINS=

# 사용자별 섹션 가시성 + 포커스 프로필 매핑 (JSON 한 줄)
# hidden_sections: 해당 유저에게 숨길 섹션 id 배열
# focus_profile: dashboard/server.py FOCUS_PROFILES 의 키 (없으면 null)
# 예: DASHBOARD_USER_PROFILES={"user1":{"hidden_sections":["section-interest-analysis"],"focus_profile":"hydrogen_carriers"}}
DASHBOARD_USER_PROFILES=

# ──────────────────────────────────────────────
# 레거시 (하위 호환용 · 신규 배포 시 불필요)
# ──────────────────────────────────────────────
# DASHBOARD_USERNAME=
# DASHBOARD_PASSWORD_HASH=
